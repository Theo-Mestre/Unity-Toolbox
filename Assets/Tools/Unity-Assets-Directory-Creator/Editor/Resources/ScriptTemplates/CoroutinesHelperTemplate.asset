  templateName: Coroutine Helper
  templateContent: "using System.Collections;\r\nusing System;\r\nusing UnityEngine;\r\n\r\npublic
    static class {ClassName}\r\n{\r\n    public static IEnumerator WaitAndExecute(float
    delay, Action action)\r\n    {\r\n        yield return new WaitForSeconds(delay);\r\n       
    action?.Invoke();\r\n    }\r\n}\r\n"
  description: A static class to manage coroutine
